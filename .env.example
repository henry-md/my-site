# Debugging
VITE_DEBUG_UI=false

# TikTok Business API OAuth Callback And Exchange
# TikTok Business API OAuth settings for the Express server.
# Set real values in Railway or local .env; never expose TIKTOK_APP_SECRET to browser code.
TIKTOK_REDIRECT_URI=https://henry-deutsch.com/tiktok/callback
TIKTOK_APP_ID=  # Identifies the TikTok app in the developer portal (which developer app is making this request?)
TIKTOK_APP_SECRET=  # Authenticates the app id
TIKTOK_ADVERTISER_ID=  # Specifies which ad account the developer app is associated with. Technically, you could manage multiple ad accounts with a single developer app.
TIKTOK_EXCHANGE_ADMIN_SECRET=  # Optional guard for the private token exchange endpoint.

# Received after the TikTok handshake. Can copy to other apps to generate new access tokens.
TIKTOK_REFRESH_TOKEN=
